# Postgres
DATABASE_URL=postgres://qm:qm@db:5432/qualitymate

# Better-auth
BETTER_AUTH_SECRET=replace-with-32-byte-random-string
BETTER_AUTH_URL=http://localhost:3000

# Recovery — if set and admin table is empty, /setup unlocks for re-bootstrap.
# Generate with: openssl rand -base64 24
RECOVERY_PASSPHRASE=

# Encryption-at-rest key for secret settings (SMTP password, AI key, S3 creds).
# REQUIRED in production. Changing it makes existing encrypted settings unreadable.
# Generate with: openssl rand -base64 32
INSTALL_PASSPHRASE=

# Public app URL (used in emails, PDFs)
APP_URL=http://localhost:3000

# Local uploads dir — Docker volume in production
UPLOADS_DIR=/app/data/uploads

# Released image to run. Customers pull `:1-stable`. Stay on `:1-stable-rc` only if you opt in to canary.
APP_IMAGE=ghcr.io/karldedekind/qualitymate:1-stable

# Watchtower auto-update.
# Default: enabled, monthly at 04:00 UTC on the 1st (cron has 6 fields incl. seconds).
# To disable: set WATCHTOWER_ENABLED=false AND WATCHTOWER_PROFILE=disabled.
WATCHTOWER_ENABLED=true
WATCHTOWER_PROFILE=watchtower
WATCHTOWER_SCHEDULE=0 0 4 1 * *
